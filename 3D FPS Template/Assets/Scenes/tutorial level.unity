  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  interactTag: Player
  interactKey: 102
  inputInteraction: 1
  hintText: 
  interactPressed: 0
  dialog:
  - Text: "\u010Cus, jak to jde? Vypad\xE1\u0161 vystresovan\u011B."
  - Text: "Ahoj Filipe...no...ono to vypad\xE1 \u017Ee brzy vybuchne slunce...nevim
      co d\u011Blat..."
  - Text: "Jo tak to zajdi za milanem. On o konci sv\u011Bta bl\xE1bol\xED furt,
      tak\u017Ee ten ti asi porad\xED."
  - Text: "D\xEDky, zept\xE1m se ho."
