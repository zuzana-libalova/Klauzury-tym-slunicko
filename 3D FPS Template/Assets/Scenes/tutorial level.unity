      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.size
      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[0].Text
      value: Ahoj Milane, um, jak se m-
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[1].Text
      value: "Nemus\xED\u0161 mi nic \u0159\xEDkat, \u010Dlov\u011B\u010De. Astar
        \u0160eran mi ji\u017E v\u0161e vyjevil."
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[2].Text
      value: "Za chvilku bude slunce zni\u010Deno, a lidstvo t\u011B\u017Ece zaplat\xED
        za sv\xE9 h\u0159\xEDchy."
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[3].Text
      value: "Te\u010F m\xE1\u0161 posledn\xED \u0161anci, mus\xED\u0161 j\xEDt ven,
        varovat sv\xE9 sousedy ne\u017E zem\u0159ou."
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[4].Text
      value: "Jdi p\u0159ed d\u016Fm, j\xE1 tam na tebe budu \u010Dekat."
      objectReference: {fileID: 0}
    - target: {fileID: 7306520069174084815, guid: f821ec93dd19bc34485a6894a1617dd5, type: 3}
      propertyPath: dialog.Array.data[5].Text
      value: ...Ok??
      objectReference: {fileID: 0}
